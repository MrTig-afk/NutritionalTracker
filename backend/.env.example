# NutriScan backend — environment template.
# Copy to `backend/.env` and fill in real values. NEVER commit the real .env.

# --- Database (Postgres / Neon) ---
# Use a LEAST-PRIVILEGE role (no BYPASSRLS) so row-level security actually applies.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Supabase (auth) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- AI providers ---
GOOGLE_API_KEY=your-gemini-api-key      # Gemini (label scanning)
GROQ_API_KEY=your-groq-api-key          # Groq (chat assistant)
# Optional model/guardrail overrides:
# GROQ_CHAT_MODEL=openai/gpt-oss-120b
# GROQ_GUARD_MODEL=meta-llama/llama-guard-4-12b
# CHAT_MODERATION_ENABLED=0

# --- Image storage (AWS S3, optional — omit to run in demo mode) ---
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-southeast-2
S3_BUCKET_NAME=your-bucket-name

# --- Web push (VAPID) ---
# Generate: pip install pywebpush && vapid --gen && vapid --applicationServerKey
VAPID_PRIVATE_KEY=your-vapid-private-key   # PEM contents, \n for newlines
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_CLAIM=mailto:you@example.com
ADMIN_USER_ID=                             # user id that receives admin push alerts

# --- Developer ops alerts ---
NTFY_TOPIC=                                # ntfy.sh topic for error/ops alerts (e.g. myapp-alerts-x7k2)

# --- Notifications / scheduling (optional) ---
# MEAL_REMINDERS_ENABLED=0
# REMINDER_UTC_OFFSET_MIN=600              # user timezone offset in minutes (AEST = 600)

# --- Misc ---
# ENABLE_DOCS=0                            # set 1 to expose /docs (keep off in prod)
