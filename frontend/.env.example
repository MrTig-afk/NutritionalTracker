# NutriScan frontend — environment template.
# Copy to `frontend/.env` and fill in real values. Only VITE_* vars are exposed
# to the browser bundle, so put NO secrets here (anon key is public by design).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_URL=https://your-backend.onrender.com
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
